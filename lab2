def center_pad_to_1s(audio_np, target_len=SR):
    audio_np = np.asarray(audio_np, dtype=np.float32)

    if len(audio_np) >= target_len:
        start = (len(audio_np) - target_len) // 2
        return audio_np[start:start + target_len]

    pad_total = target_len - len(audio_np)
    pad_left = pad_total // 2
    pad_right = pad_total - pad_left
    return np.pad(audio_np, (pad_left, pad_right), mode="constant")

def predict_audio_array(audio, sr=SR):
    audio = center_pad_to_1s(audio, SR)

    mel = librosa.feature.melspectrogram(
        y=audio, sr=sr, n_fft=512, hop_length=160, n_mels=64
    )
    mel_db = librosa.power_to_db(mel, ref=np.max).astype(np.float32)

    mel_db = (mel_db - train_mean) / train_std
    inp = mel_db[np.newaxis, ..., np.newaxis]

    probs = model.predict(inp, verbose=0)[0]
    pred_id = int(np.argmax(probs))
    pred_word = ID_TO_CLASS[pred_id]
    pred_token = WORD_TO_TOKEN[pred_word]
    conf = float(np.max(probs))

    return pred_word, pred_token, conf

def generate_sequence_audio(words, out_path="/content/test_sequence.wav", pause_ms=650, tld="com"):
    combined = AudioSegment.silent(duration=400)

    for w in words:
        temp_mp3 = f"/content/{w}.mp3"
        temp_wav = f"/content/{w}.wav"

        tts = gTTS(text=w, lang="en", tld=tld, slow=False)
        tts.save(temp_mp3)

        seg = AudioSegment.from_mp3(temp_mp3).set_channels(1).set_frame_rate(SR)

        if len(seg) > 900:
            seg = seg[:900]

        seg = AudioSegment.silent(duration=100) + seg + AudioSegment.silent(duration=100)
        seg.export(temp_wav, format="wav")
        seg = AudioSegment.from_wav(temp_wav)

        combined += seg + AudioSegment.silent(duration=pause_ms)

        os.remove(temp_mp3)
        os.remove(temp_wav)

    combined.export(out_path, format="wav")
    return out_path

def split_sequence_file(file_path, min_silence_len=300, silence_thresh_offset=20, keep_silence=250):
    audio = AudioSegment.from_wav(file_path)

    chunks = split_on_silence(
        audio,
        min_silence_len=min_silence_len,
        silence_thresh=audio.dBFS - silence_thresh_offset,
        keep_silence=keep_silence
    )
    return chunks

