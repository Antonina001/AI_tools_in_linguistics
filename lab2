def add_noise(y, level=0.003):
    noise = np.random.randn(len(y)) * level
    return np.clip(y + noise, -1.0, 1.0)

def synthesize_base_word(word, out_wav, tld="com", slow=False):
    mp3_path = out_wav.replace(".wav", ".mp3")
    tts = gTTS(text=word, lang="en", tld=tld, slow=slow)
    tts.save(mp3_path)

    audio = AudioSegment.from_mp3(mp3_path).set_channels(1).set_frame_rate(SR)

    if len(audio) > 900:
        audio = audio[:900]

    audio = AudioSegment.silent(duration=100) + audio + AudioSegment.silent(duration=100)
    audio.export(out_wav, format="wav")

    os.remove(mp3_path)

def save_augmented_versions(wav_path):
    y, sr = librosa.load(wav_path, sr=SR)
    y = librosa.util.fix_length(y, size=SR)

    sf.write(wav_path.replace(".wav", "_orig.wav"), y, sr)

    y_fast = librosa.effects.time_stretch(y, rate=1.08)
    y_fast = librosa.util.fix_length(y_fast, size=SR)
    sf.write(wav_path.replace(".wav", "_fast.wav"), y_fast, sr)

    y_slow = librosa.effects.time_stretch(y, rate=0.92)
    y_slow = librosa.util.fix_length(y_slow, size=SR)
    sf.write(wav_path.replace(".wav", "_slow.wav"), y_slow, sr)

    y_noise = add_noise(y, level=0.004)
    sf.write(wav_path.replace(".wav", "_noise.wav"), y_noise, sr)

# 1. Створюємо базові записи
base_samples = {word: [] for word in CLASSES}

for word in CLASSES:
    for i, tld in enumerate(TLDS):
        base_wav = os.path.join(BASE_DIR, f"{word}_base_{i}.wav")
        synthesize_base_word(word, base_wav, tld=tld, slow=(i == len(TLDS)-1))
        base_samples[word].append(base_wav)

# 2. Ділимо базові записи на train/val/test
splits = {"train": [], "val": [], "test": []}

for word in CLASSES:
    files_word = base_samples[word][:]
    random.shuffle(files_word)

    n = len(files_word)
    n_train = max(4, int(0.67 * n))
    n_val = 1
    n_test = n - n_train - n_val

    train_files = files_word[:n_train]
    val_files   = files_word[n_train:n_train+n_val]
    test_files  = files_word[n_train+n_val:]

    for split_name, subset in [("train", train_files), ("val", val_files), ("test", test_files)]:
        for f in subset:
            split_dir = os.path.join(BASE_DIR, split_name, word)
            os.makedirs(split_dir, exist_ok=True)

            target_base = os.path.join(split_dir, os.path.splitext(os.path.basename(f))[0])
            save_augmented_versions(target_base + ".wav") if False else None  # заглушка

            # копіюємо базовий файл у split і робимо аугментації вже всередині split
            shutil.copy(f, target_base + ".wav")
            save_augmented_versions(target_base + ".wav")
            os.remove(target_base + ".wav")  # залишаємо тільки аугментовані версії

print("Датасет сформовано.")

for split_name in ["train", "val", "test"]:
    total = 0
    for word in CLASSES:
        class_dir = os.path.join(BASE_DIR, split_name, word)
        cnt = len(os.listdir(class_dir))
        total += cnt
        print(f"{split_name:5s} | {word:8s} -> {cnt}")
    print(f"Усього {split_name}: {total}\n")

def load_split(split_name):
    X_list, y_list = [], []

    for class_name in CLASSES:
        class_dir = os.path.join(BASE_DIR, split_name, class_name)
        for fname in os.listdir(class_dir):
            if fname.endswith(".wav"):
                fpath = os.path.join(class_dir, fname)

                audio, sr = librosa.load(fpath, sr=SR)
                audio = librosa.util.fix_length(audio, size=SR)

                mel = librosa.feature.melspectrogram(
                    y=audio, sr=sr, n_fft=512, hop_length=160, n_mels=64
                )
                mel_db = librosa.power_to_db(mel, ref=np.max).astype(np.float32)

                X_list.append(mel_db)
                y_list.append(CLASS_TO_ID[class_name])

    X = np.array(X_list, dtype=np.float32)
    y = np.array(y_list, dtype=np.int32)

    idx = np.arange(len(X))
    np.random.shuffle(idx)
    X, y = X[idx], y[idx]

    return X, y

X_train, y_train = load_split("train")
X_val, y_val = load_split("val")
X_test, y_test = load_split("test")

train_mean = X_train.mean()
train_std = X_train.std() + 1e-8

X_train = ((X_train - train_mean) / train_std)[..., np.newaxis]
X_val   = ((X_val - train_mean) / train_std)[..., np.newaxis]
X_test  = ((X_test - train_mean) / train_std)[..., np.newaxis]

