import os
import uuid
import gradio as gr
from gtts import gTTS

MAX_FILES = 5

def make_voice(text_value, lang_value, slow_value, file_state):

    clean_text = (text_value or "").strip()

    if clean_text == "":
        return None, file_state, gr.update(value=[]), "Спочатку введіть текст."

    lang_codes = {
        "Українська": "uk",
        "Англійська": "en"
    }

    out_file = f"voice_{uuid.uuid4().hex[:12]}.mp3"

    tts = gTTS(
        text=clean_text,
        lang=lang_codes[lang_value],
        slow=slow_value
    )

    tts.save(out_file)

    saved_files = list(file_state) if file_state else []
    saved_files.insert(0, out_file)
    saved_files = saved_files[:MAX_FILES]

    return out_file, saved_files, gr.update(value=saved_files), "Файл створено."


def clear_form():
    return "", "Українська", False, None, "Форму очищено."


def clear_history(files):

    if files:
        for f in files:
            if isinstance(f, str) and os.path.exists(f):
                try:
                    os.remove(f)
                except:
                    pass

    return [], gr.update(value=[]), "Історію очищено."


with gr.Blocks(title="Text Speech Generator", theme=gr.themes.Monochrome()) as demo:

    gr.Markdown("## Генерація мовлення з тексту")

    files_state = gr.State([])

    with gr.Row():

        with gr.Column(scale=2):

            source_text = gr.TextArea(
                label="Введіть текст",
                placeholder="Напишіть текст для озвучення...",
                lines=10
            )

            language_select = gr.Dropdown(
                choices=["Українська", "Англійська"],
                value="Українська",
                label="Оберіть мову"
            )

            slow_mode = gr.Checkbox(
                label="Повільне читання",
                value=False
            )

            with gr.Row():
                generate_btn = gr.Button("Створити MP3", variant="primary")
                clear_btn = gr.Button("Очистити")

        with gr.Column(scale=1):

            audio_result = gr.Audio(
                label="Згенероване аудіо",
                type="filepath"
            )

            saved_files = gr.File(
                label="Останні створені файли",
                file_count="multiple"
            )

            clear_history_btn = gr.Button("Очистити історію")

            status_box = gr.Textbox(
                label="Статус",
                interactive=False
            )

    generate_btn.click(
        fn=make_voice,
        inputs=[source_text, language_select, slow_mode, files_state],
        outputs=[audio_result, files_state, saved_files, status_box]
    )

    clear_btn.click(
        fn=clear_form,
        inputs=None,
        outputs=[source_text, language_select, slow_mode, audio_result, status_box]
    )

    clear_history_btn.click(
        fn=clear_history,
        inputs=[files_state],
        outputs=[files_state, saved_files, status_box]
    )

demo.launch(share=True)

